{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\" \"npm run dev --prefix apps/pocketbase\"",
    "build": "concurrently --raw \"npm run build --prefix apps/web\"",
    "start": "concurrently --kill-others --raw \"npm run start --prefix apps/pocketbase\"",
    "lint": "concurrently --raw \"npm run lint --prefix apps/web\"",
    "validate": "node validateProduction.js",
    "check": "npm run validate && npm run lint && npm run build",
    "sync:pocketbase": "node scripts/sync-pocketbase-deploy.js",
    "backup:pocketbase": "node scripts/backup-pocketbase.js",
    "restore:pocketbase": "node scripts/restore-pocketbase.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "@tiptap/extension-text-align": "^2.27.2"
  }
}
