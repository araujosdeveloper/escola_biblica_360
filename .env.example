# Variáveis de ambiente gerais do projeto Escola Bíblica 360
# Este arquivo é apenas um modelo.
# Não coloque senhas, tokens ou chaves reais aqui.

# URL local do PocketBase usada pelo frontend Vite.
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# URL pública do PocketBase em produção.
# Configure o valor real no provedor de deploy.
# Exemplo:
# VITE_POCKETBASE_URL=https://api.seudominio.com

# Chave de criptografia do PocketBase.
# Deve ter 32 caracteres.
# Configure o valor real somente no Railway ou no servidor.
# Nunca use o valor abaixo em produção.
PB_ENCRYPTION_KEY=change-me-to-32-characters-key

# URL pública do backend PocketBase.
# Exemplo:
# PB_PUBLIC_URL=https://api.seudominio.com
PB_PUBLIC_URL=http://127.0.0.1:8090

# Origens permitidas para CORS.
# Em desenvolvimento:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Em produção, configure domínios reais.
# Exemplo:
# CORS_ORIGINS=https://seudominio.com,https://www.seudominio.com