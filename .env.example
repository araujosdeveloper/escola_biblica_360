
# URL pública do PocketBase usada pelo frontend Vite.
# Em desenvolvimento local, normalmente use:
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# URL pública do PocketBase em produção.
# Exemplo:
# VITE_POCKETBASE_URL=https://api.seudominio.com

# Chave de criptografia usada pelo PocketBase, quando exigida no ambiente de deploy.
# Não coloque o valor real neste arquivo.
# Configure o valor real no Railway, servidor ou painel de hospedagem.
PB_ENCRYPTION_KEY=change-me-in-production

# URL pública do PocketBase usada pelo backend/deploy, quando aplicável.
# Exemplo:
# PB_PUBLIC_URL=https://api.seudominio.com
PB_PUBLIC_URL=http://127.0.0.1:8090

# Origens permitidas para CORS.
# Em desenvolvimento:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Em produção, use o domínio real do frontend.
# Exemplo:
# CORS_ORIGINS=https://seudominio.com,https://www.seudominio.com
