# Variáveis de ambiente do frontend React/Vite
# Copie este arquivo para .env quando for rodar localmente.
# Não coloque senhas, tokens ou chaves privadas aqui.
# Variáveis VITE_ ficam visíveis no navegador depois do build.

# URL local do PocketBase em desenvolvimento.
VITE_POCKETBASE_URL=http://localhost:8090

# URL local da API.
# Neste projeto, normalmente é a mesma URL do PocketBase.
VITE_API_URL=http://localhost:8090

# Exemplo de produção:
# Configure valores reais no provedor de deploy.
# VITE_POCKETBASE_URL=https://api.seudominio.com
# VITE_API_URL=https://api.seudominio.com