# Variáveis de ambiente do backend PocketBase
# Configure os valores reais no Railway ou no provedor de deploy.
# Não coloque senhas, tokens ou chaves reais no GitHub.

# Ambiente da aplicação.
NODE_ENV=production

# URL pública da API PocketBase.
# Use o domínio final do backend, sem barra no final.
# Exemplo:
# PB_PUBLIC_URL=https://api.escolabíblica360.com
PB_PUBLIC_URL=https://api.escolabíblica360.com

# Origens permitidas para CORS.
# Use o domínio público do frontend, sem barra no final.
# Para múltiplos domínios, separe por vírgula.
# Exemplo:
# CORS_ORIGINS=https://escolabíblica360.com,https://www.escolabíblica360.com
CORS_ORIGINS=https://escolabíblica360.com,https://www.escolabíblica360.com

# Chave de criptografia do PocketBase.
# Deve ter 32 caracteres.
# Gere uma chave forte e configure somente no Railway.
# Nunca use o valor abaixo em produção.
PB_ENCRYPTION_KEY=change-me-to-32-characters-key