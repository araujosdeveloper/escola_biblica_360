
# PocketBase Production Environment Variables
# Configure estas variáveis no painel do Railway (Settings > Variables)

# URL pública da sua instância do PocketBase (Backend)
PB_PUBLIC_URL=https://api.escolabiblica360.com

# Origens permitidas para requisições CORS (Domínio do Frontend - sem barra no final)
CORS_ORIGINS=https://escolabiblica360.com

# Identificador de ambiente
NODE_ENV=production
